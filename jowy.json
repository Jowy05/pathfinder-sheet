  "__feats_html": "<div class=\"feat-card normal\" data-type=\"normal\">\n    <div class=\"feat-dot\"></div>\n    <input type=\"text\" class=\"feat-name\" placeholder=\"Nombre de la dote\" value=\"Dureza\">\n    <select class=\"feat-type-sel\" onchange=\"updateFeatType(this)\">\n      <option value=\"normal\" selected=\"\">Normal</option>\n      <option value=\"cbt\">Combate</option>\n      <option value=\"meta\">Metamagia</option>\n      <option value=\"crit\">Crítico</option>\n      <option value=\"team\">Trabajo en Equipo</option>\n    </select>\n    <input type=\"text\" class=\"feat-notes\" placeholder=\"Notas / requisitos\" value=\"Req: Ninguno — +3 PG permanentes. Por cada DG extra de nivel 4 en adelante, +1 PG adicional.\">\n    <button class=\"btn-remove\" type=\"button\" aria-label=\"Eliminar dote\" title=\"Eliminar dote\" onclick=\"this.closest('.feat-card').remove(); updateFeatCounter();\"><span aria-hidden=\"true\">×</span></button></div>",
  "__features_html": "<div class=\"feature-card\">\n    <div class=\"feature-top\">\n      <input type=\"text\" class=\"feat-name feature-name-input\" placeholder=\"Nombre de la aptitud…\" value=\"Desafío\">\n      <button class=\"feature-remove-btn\" type=\"button\" aria-label=\"Eliminar aptitud\" title=\"Eliminar aptitud\" onclick=\"this.closest('.feature-card').remove();\"><span aria-hidden=\"true\">×</span></button>\n    </div>\n    <input type=\"text\" class=\"feat-notes feature-desc-input\" placeholder=\"Descripción breve, CD, efecto…\" value=\"1/día al nivel 1, +1 cada 3 niveles (máx. 7/día). Similar al desafío del caballero; el samurái jura honor ante el objetivo. El daño extra es igual a su nivel.\">\n    <div class=\"feature-tracker\">\n      <span class=\"tracker-label\">Usos/Día:</span>\n      <div class=\"tracker-bubbles\"><div class=\"tracker-bubble\" onclick=\"toggleBubble(this)\" title=\"Disponible — clic para gastar\"></div></div>\n      <input type=\"number\" class=\"tracker-max-input\" value=\"1\" min=\"0\" max=\"40\" title=\"Máx. usos por día\" onchange=\"rebuildBubbles(this)\" onblur=\"rebuildBubbles(this)\">\n      <button class=\"tracker-reset-btn\" onclick=\"resetBubbles(this)\" title=\"Recuperar todos los usos\">Descanso</button>\n    </div></div><div class=\"feature-card\">\n    <div class=\"feature-top\">\n      <input type=\"text\" class=\"feat-name feature-name-input\" placeholder=\"Nombre de la aptitud…\" value=\"Resolución\">\n      <button class=\"feature-remove-btn\" type=\"button\" aria-label=\"Eliminar aptitud\" title=\"Eliminar aptitud\" onclick=\"this.closest('.feature-card').remove();\"><span aria-hidden=\"true\">×</span></button>\n    </div>\n    <input type=\"text\" class=\"feat-notes feature-desc-input\" placeholder=\"Descripción breve, CD, efecto…\" value=\"A nivel 1, el samurái puede usar su determinación para resistir efectos. Puede usarse 1/día por cada 2 niveles de samurái.\">\n    <div class=\"feature-tracker\">\n      <span class=\"tracker-label\">Usos/Día:</span>\n      <div class=\"tracker-bubbles\"><div class=\"tracker-bubble\" onclick=\"toggleBubble(this)\" title=\"Disponible — clic para gastar\"></div></div>\n      <input type=\"number\" class=\"tracker-max-input\" value=\"1\" min=\"0\" max=\"40\" title=\"Máx. usos por día\" onchange=\"rebuildBubbles(this)\" onblur=\"rebuildBubbles(this)\">\n      <button class=\"tracker-reset-btn\" onclick=\"resetBubbles(this)\" title=\"Recuperar todos los usos\">Descanso</button>\n    </div></div><div class=\"feature-card\">\n    <div class=\"feature-top\">\n      <input type=\"text\" class=\"feat-name feature-name-input\" placeholder=\"Nombre de la aptitud…\" value=\"Desafío Glorioso\">\n      <button class=\"feature-remove-btn\" type=\"button\" aria-label=\"Eliminar aptitud\" title=\"Eliminar aptitud\" onclick=\"this.closest('.feature-card').remove();\"><span aria-hidden=\"true\">×</span></button>\n    </div>\n    <input type=\"text\" class=\"feat-notes feature-desc-input\" placeholder=\"Descripción breve, CD, efecto…\" value=\"Al reducir al objetivo de tu Desafío a 0 PG o menos, puedes emitir un Desafío Glorioso contra otro oponente en 15 pies como acción inmediata (sin gastar uso diario). Cada desafío consecutivo impone −2 CA acumulativo pero otorga +2×N al daño c.a.c. contra el objetivo (N = desafíos gloriosos consecutivos).\">\n    <div class=\"feature-tracker\">\n      <span class=\"tracker-label\">Usos/Día:</span>\n      <div class=\"tracker-bubbles\"></div>\n      <input type=\"number\" class=\"tracker-max-input\" value=\"0\" min=\"0\" max=\"40\" title=\"Máx. usos por día\" onchange=\"rebuildBubbles(this)\" onblur=\"rebuildBubbles(this)\">\n      <button class=\"tracker-reset-btn\" onclick=\"resetBubbles(this)\" title=\"Recuperar todos los usos\">Descanso</button>\n    </div></div><div class=\"feature-card\">\n    <div class=\"feature-top\">\n      <input type=\"text\" class=\"feat-name feature-name-input\" placeholder=\"Nombre de la aptitud…\" value=\"Embestida Imprudente\">\n      <button class=\"feature-remove-btn\" type=\"button\" aria-label=\"Eliminar aptitud\" title=\"Eliminar aptitud\" onclick=\"this.closest('.feature-card').remove();\"><span aria-hidden=\"true\">×</span></button>\n    </div>\n    <input type=\"text\" class=\"feat-notes feature-desc-input\" placeholder=\"Descripción breve, CD, efecto…\" value=\"Al tirar iniciativa, si obtienes 11 o más en el dado, puedes moverte hasta tu velocidad base como acción inmediata. No estás desprevenido durante este movimiento. La distancia movida se resta de tu movimiento en el primer turno.\">\n    <div class=\"feature-tracker\">\n      <span class=\"tracker-label\">Usos/Día:</span>\n      <div class=\"tracker-bubbles\"></div>\n      <input type=\"number\" class=\"tracker-max-input\" value=\"0\" min=\"0\" max=\"40\" title=\"Máx. usos por día\" onchange=\"rebuildBubbles(this)\" onblur=\"rebuildBubbles(this)\">\n      <button class=\"tracker-reset-btn\" onclick=\"resetBubbles(this)\" title=\"Recuperar todos los usos\">Descanso</button>\n    </div></div>",
